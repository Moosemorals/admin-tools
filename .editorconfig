# EditorConfig — https://editorconfig.org
root = true

[*]
charset                  = utf-8
end_of_line              = lf
insert_final_newline     = true
trim_trailing_whitespace = true
indent_style             = space
indent_size              = 4

[*.{js,css,html,yml,yaml,json}]
indent_size = 2

[*.js]
# ES modules (import/export) only — no CommonJS (require/module.exports).
# Single quotes for string literals; template literals for interpolation.
# Semicolons at the end of every statement.
# K&R brace style — opening brace on the same line as the statement.
# Prefer const for bindings that are never reassigned; let for mutable; never var.
# JSDoc comments on every exported function, documenting params and return type.

[*.cs]
# K&R: opening brace on the same line as the statement/declaration.
csharp_new_line_before_open_brace  = none
csharp_new_line_before_else        = false
csharp_new_line_before_catch       = false
csharp_new_line_before_finally     = false

# Braces are never optional.
csharp_prefer_braces = true:error

# Block-scoped namespaces (not file-scoped).
csharp_style_namespace_declarations = block_scoped:error

# using directives belong inside the namespace block.
csharp_using_directive_placement = inside_namespace:error

# All non-interface members must have explicit accessibility modifiers.
dotnet_style_require_accessibility_modifiers = for_non_interface_members:error

# Modifier order: static before readonly.
csharp_preferred_modifier_order = public, private, protected, internal, file, new, static, abstract, virtual, sealed, override, readonly, extern, unsafe, volatile, async, required:error

# SPDX file header on every authored source file.
file_header_template = SPDX-FileCopyrightText: Copyright (c) 2026 Osric Wilkinson\nSPDX-License-Identifier: MIT
dotnet_diagnostic.ide0073.severity = error

# Extension methods are the preferred way to group related operations on a type
# (e.g. app.MapCopilotApi(), builder.AddCopilotServices()).
# There is no formal Roslyn rule for this — it is a project convention.

# EF Core migration files are auto-generated; exclude style rules.
[**/Migrations/*.cs]
dotnet_diagnostic.ide0036.severity = none
dotnet_diagnostic.ide0065.severity = none
dotnet_diagnostic.ide0073.severity = none
dotnet_diagnostic.ide0161.severity = none
