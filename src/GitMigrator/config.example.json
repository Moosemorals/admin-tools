{
  // Absolute (or relative) path to the folder where all repositories will be cloned.
  // Sub-directories are created automatically:
  //   <targetFolder>/github.com/<owner>/<repo>
  //   <targetFolder>/gitlab.com/<namespace>/<repo>    (or the self-hosted host)
  //   <targetFolder>/lan/<hostname>/<absolute-path-on-host>
  "targetFolder": "/home/alice/repos",

  // Optional: override the location of the state file used for resume support.
  // Defaults to <targetFolder>/.migration-state.json
  "stateFile": "/home/alice/repos/.migration-state.json",

  // true  → log what would happen but do not clone or modify anything.
  "dryRun": false,

  // true  → use SSH URLs for GitHub/GitLab (requires SSH keys to be configured).
  // false → use HTTPS with embedded access token (token is stripped from .git/config after clone).
  "preferSsh": false,

  "sources": [
    // ── GitHub ──────────────────────────────────────────────────────────────
    {
      "type": "github",
      // Personal access token (classic) with 'repo' scope, or a fine-grained PAT
      // with read access to the repositories you want to migrate.
      "token": "ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx",
      // Usernames to migrate. If empty, the authenticated user is used.
      "users": ["alice"],
      // Organisations to migrate (optional).
      "orgs": ["my-company"]
    },

    // ── GitLab (cloud) ──────────────────────────────────────────────────────
    {
      "type": "gitlab",
      // Personal access token with 'read_api' and 'read_repository' scopes.
      "token": "glpat-xxxxxxxxxxxxxxxxxxxxxxxxxxxx",
      // Default: https://gitlab.com  – override for self-hosted instances.
      "baseUrl": "https://gitlab.com",
      "users": ["alice"],
      "groups": ["my-group", "my-group/subgroup"]
    },

    // ── GitLab (self-hosted example) ────────────────────────────────────────
    {
      "type": "gitlab",
      "token": "glpat-xxxxxxxxxxxxxxxxxxxxxxxxxxxx",
      "baseUrl": "https://gitlab.company.internal",
      "users": [],
      "groups": ["engineering"]
    },

    // ── LAN machine – explicit repo list ────────────────────────────────────
    {
      "type": "lan",
      "host": "devbox",         // hostname or IP
      "user": "alice",          // SSH user (omit to use your default SSH config)
      "sshPort": 22,
      // Explicit absolute paths to git repos on the remote machine.
      "repos": [
        "/home/alice/projects/myapp",
        "/home/alice/projects/scripts"
      ],
      // Directories to scan recursively for git repos (optional).
      "scanPaths": [],
      "maxScanDepth": 5
    },

    // ── LAN machine – auto-scan example ─────────────────────────────────────
    {
      "type": "lan",
      "host": "nas.local",
      "user": "git",
      "repos": [],
      "scanPaths": [
        "/srv/git",
        "/home/git/projects"
      ],
      "maxScanDepth": 4
    }
  ]
}
